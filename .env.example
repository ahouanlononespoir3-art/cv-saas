# ─── APP ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="CVPro AI"

# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/cvpro_db"

# ─── AUTH ────────────────────────────────────────────────────────────────────
AUTH_SECRET="your-super-secret-key-min-32-chars-change-this"
AUTH_TRUST_HOST=true

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── AI ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY="gsk_votre-cle-groq-ici"

# ─── STRIPE ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_PREMIUM_PRICE_ID="price_your-premium-price-id"

# ─── EMAIL ───────────────────────────────────────────────────────────────────
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="your@email.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="CVPro AI <noreply@cvpro.ai>"

